# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit your real keys.

# ── Anthropic ────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── GitHub (for GitHub job source) ───────────────────────────────────────────
# Get from: https://github.com/settings/tokens → Generate new token (classic)
# Required scopes: none (public repo read is enough — no scopes needed)
# Without this the GitHub API rate limit is 60 req/hr; with it, 5000 req/hr.
GITHUB_TOKEN=your_github_personal_access_token_here
